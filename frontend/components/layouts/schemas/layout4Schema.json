{
  "layout_id": "layout_4",
  "name": "Magazine Style",
  "description": "Editorial magazine-inspired layout with multi-column text and image combinations. Professional and modern.",
  "version": "1.0",
  "thumbnail": "/layout-previews/layout4.jpg",
  
  "supported_slots": {
    "photos": {
      "couplePhoto": {
        "required": true,
        "description": "Main couple photo for magazine cover",
        "supports_border": true,
        "default_position": "left",
        "aspect_ratio": "portrait"
      },
      "bridePhoto": {
        "required": false,
        "description": "Bride feature photo",
        "supports_border": false,
        "aspect_ratio": "portrait"
      },
      "groomPhoto": {
        "required": false,
        "description": "Groom feature photo",
        "supports_border": false,
        "aspect_ratio": "portrait"
      },
      "coverPhotos": {
        "required": false,
        "type": "array",
        "max_count": 3,
        "description": "Featured editorial photos"
      },
      "preciousMoments": {
        "required": false,
        "type": "array",
        "max_count": 12,
        "description": "Gallery in magazine grid layout",
        "supports_border": false,
        "layout_style": ["masonry", "grid"]
      },
      "studioImage": {
        "required": false,
        "description": "Studio logo for credits",
        "supports_border": false
      }
    },
    
    "videos": {
      "preWeddingVideo": {
        "required": false,
        "description": "Featured video story",
        "embed_type": "youtube"
      }
    },
    
    "text_content": {
      "welcomeMessage": {
        "required": true,
        "max_length": 100,
        "description": "Magazine headline"
      },
      "description": {
        "required": false,
        "max_length": 800,
        "description": "Feature article text / love story"
      }
    },
    
    "studio_info": {
      "studioName": {
        "required": false,
        "description": "Photography credits"
      },
      "studioContact": {
        "required": false,
        "description": "Studio contact info"
      }
    },
    
    "backgrounds": {
      "heroBackground": {
        "required": false,
        "description": "Cover background"
      }
    }
  },
  
  "style_inputs": {
    "font": {
      "required": true,
      "default": "Inter",
      "description": "Editorial font (sans-serif recommended)"
    },
    "primaryColor": {
      "required": true,
      "default": "#1f2937",
      "description": "Primary text color (dark)"
    },
    "secondaryColor": {
      "required": true,
      "default": "#6b7280",
      "description": "Secondary accent color"
    }
  },
  
  "border_slots": {
    "coupleBorder": {
      "applies_to": ["couplePhoto"],
      "required": false,
      "description": "Border for cover photo"
    }
  },
  
  "layout_structure": {
    "sections": [
      "magazine_cover",
      "feature_article",
      "photo_spread",
      "editorial_grid",
      "live_feature",
      "credits"
    ],
    "responsive_breakpoints": {
      "mobile": "640px",
      "tablet": "768px",
      "desktop": "1024px"
    }
  }
}