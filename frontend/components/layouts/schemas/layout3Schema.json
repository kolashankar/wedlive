{
  "layout_id": "layout_3",
  "name": "Horizontal Timeline",
  "description": "Journey-style layout with bride and groom photos connected by a timeline, featuring couple photo at the convergence point.",
  "version": "1.0",
  "thumbnail": "/layout-previews/layout3.jpg",
  
  "supported_slots": {
    "photos": {
      "bridePhoto": {
        "required": false,
        "description": "Bride's individual photo (circular frame)",
        "supports_border": true,
        "default_position": "left",
        "aspect_ratio": "square"
      },
      "groomPhoto": {
        "required": false,
        "description": "Groom's individual photo (circular frame)",
        "supports_border": true,
        "default_position": "right",
        "aspect_ratio": "square"
      },
      "couplePhoto": {
        "required": true,
        "description": "Main couple photo (circular frame at center)",
        "supports_border": true,
        "default_position": "center",
        "aspect_ratio": "square"
      },
      "preciousMoments": {
        "required": false,
        "type": "array",
        "max_count": 20,
        "description": "Horizontal scrolling gallery",
        "supports_border": true,
        "layout_style": ["horizontal-scroll"]
      }
    },
    
    "videos": {
      "preWeddingVideo": {
        "required": false,
        "description": "YouTube embed URL for pre-wedding video",
        "embed_type": "youtube"
      }
    },
    
    "text_content": {
      "welcomeMessage": {
        "required": true,
        "max_length": 100,
        "description": "Journey-themed welcome text"
      },
      "description": {
        "required": false,
        "max_length": 400,
        "description": "Love story or relationship journey"
      }
    },
    
    "studio_info": {
      "studioName": {
        "required": false,
        "description": "Photography studio name"
      },
      "studioWebsite": {
        "required": false,
        "description": "Studio website URL"
      }
    },
    
    "backgrounds": {
      "heroBackground": {
        "required": false,
        "description": "Hero section background image"
      }
    }
  },
  
  "style_inputs": {
    "font": {
      "required": true,
      "default": "Montserrat",
      "description": "Primary font family"
    },
    "primaryColor": {
      "required": true,
      "default": "#ec4899",
      "description": "Primary brand color (hex)"
    },
    "secondaryColor": {
      "required": true,
      "default": "#8b5cf6",
      "description": "Secondary accent color (hex)"
    }
  },
  
  "border_slots": {
    "brideGroomBorder": {
      "applies_to": ["bridePhoto", "groomPhoto"],
      "required": false,
      "description": "Border style for individual photos"
    },
    "coupleBorder": {
      "applies_to": ["couplePhoto"],
      "required": false,
      "description": "Border style for couple photo"
    },
    "preciousMomentsBorder": {
      "applies_to": ["preciousMoments"],
      "required": false,
      "description": "Border style for gallery photos"
    }
  },
  
  "layout_structure": {
    "sections": [
      "hero_timeline",
      "event_details",
      "countdown",
      "description",
      "precious_moments_horizontal",
      "live_stream",
      "studio_details"
    ],
    "responsive_breakpoints": {
      "mobile": "640px",
      "tablet": "768px",
      "desktop": "1024px"
    }
  }
}